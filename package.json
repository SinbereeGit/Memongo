{
  "name": "memongo",
  "version": "2.0.2",
  "description": "A minimal MongoDB-like in-memory JSON database with pluggable persistence.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "cross-env TS_NODE_PROJECT=tsconfig.test.json node --import ./scripts/register-ts-node-esm.mjs ./node_modules/mocha/bin/mocha.js",
    "build": "tsc -p tsconfig.build.json",
    "perf": "cross-env TS_NODE_PROJECT=tsconfig.test.json node --import ./scripts/register-ts-node-esm.mjs ./test/performance/tmp.perf.ts",
    "docs": "typedoc",
    "changeset": "changeset",
    "release:prepare": "changeset version"
  },
  "keywords": [
    "database",
    "mongodb",
    "json",
    "in-memory",
    "nosql",
    "wechat-miniprogram"
  ],
  "author": "Sinber",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SinbereeGit/memongo.git"
  },
  "homepage": "https://github.com/SinbereeGit/memongo",
  "bugs": {
    "url": "https://github.com/SinbereeGit/memongo/issues"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "mocha": {
      "diff": "8.0.3",
      "serialize-javascript": "7.0.4"
    }
  }
}
